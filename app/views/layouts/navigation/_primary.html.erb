<nav
  id="default-sidebar"
  class="
    w-48 h-full transition-transform
    @container @max-[42rem]:w-16
  "
  aria-label="Sidebar"
>
  <div
    class="
      h-full overflow-y-auto bg-neutral-primary-soft
      border-e border-default min-w-16 flex flex-col
    "
  >
    <div class="px-3 py-3 border-b border-default">
      <% if @workspaces.size > 1 %>
        <details class="group">
          <summary class="flex items-center justify-between cursor-pointer list-none px-2 py-1.5 rounded-base hover:bg-neutral-tertiary">
            <div class="flex items-center gap-2 min-w-0">
              <svg class="w-4 h-4 shrink-0 text-body-secondary" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6c0-.6.4-1 1-1h16a1 1 0 0 1 1 1v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6Zm0 5h18M7 16h.01M11 16h2"/>
              </svg>
              <span class="text-sm font-medium text-heading truncate @max-[10rem]:hidden"><%= current_workspace.name %></span>
            </div>
            <svg class="w-3 h-3 text-body-secondary shrink-0 @max-[10rem]:hidden" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19 9-7 7-7-7"/>
            </svg>
          </summary>
          <ul class="mt-1 space-y-0.5 pb-1">
            <% @workspaces.each do |workspace| %>
              <li>
                <%= link_to workspace_messages_path(workspace),
                  class: "flex items-center px-2 py-1.5 text-sm rounded-base hover:bg-neutral-tertiary @max-[10rem]:hidden #{workspace == current_workspace ? "text-fg-brand font-medium" : "text-body"}" do %>
                  <%= workspace.name %>
                <% end %>
              </li>
            <% end %>
            <li class="mt-1 pt-1 border-t border-default">
              <%= link_to new_workspace_path,
                class: "flex items-center gap-1.5 px-2 py-1.5 text-sm rounded-base text-body-secondary hover:bg-neutral-tertiary hover:text-body @max-[10rem]:hidden" do %>
                <svg class="w-3.5 h-3.5 shrink-0" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7-7v14"/>
                </svg>
                <%= translate("workspaces.switcher.new") %>
              <% end %>
            </li>
          </ul>
        </details>
      <% else %>
        <div class="flex items-center justify-between px-2 py-1.5">
          <div class="flex items-center gap-2 min-w-0">
            <svg class="w-4 h-4 shrink-0 text-body-secondary" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6c0-.6.4-1 1-1h16a1 1 0 0 1 1 1v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6Zm0 5h18M7 16h.01M11 16h2"/>
            </svg>
            <span class="text-sm font-medium text-heading truncate @max-[10rem]:hidden"><%= current_workspace.name %></span>
          </div>
          <%= link_to new_workspace_path,
            class: "shrink-0 text-body-secondary hover:text-body @max-[10rem]:hidden",
            title: translate("workspaces.switcher.new") do %>
            <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14m-7-7v14"/>
            </svg>
          <% end %>
        </div>
      <% end %>
    </div>

    <ul class="space-y-2 font-medium px-3 py-4 flex-1">
      <li>
        <%= render(UI::NavigationItem.new(:href => root_path)) do |item| %>
          <% item.with_icon do %>
            <svg
              class="w-5 h-5 transition duration-75 group-hover:text-fg-brand"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              fill="none"
              viewBox="0 0 24 24"
            >
              <path
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 6.025A7.5 7.5 0 1 0 17.975 14H10V6.025Z"
              />

              <path
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13.5 3c-.169 0-.334.014-.5.025V11h7.975c.011-.166.025-.331.025-.5A7.5 7.5 0 0 0 13.5 3Z"
              />
            </svg>
          <% end %>
          <% item.with_label { translate("navigation.dashboard") } %>
        <% end %>
      </li>

      <li>
        <%= render(UI::NavigationItem.new(:href => workspace_messages_path(current_workspace))) do |item| %>
          <% item.with_icon do %>
            <svg
              class="w-5 h-5 transition duration-75 group-hover:text-fg-brand"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              fill="none"
              viewBox="0 0 24 24"
            >
              <path
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 18V8a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1Zm0-10 8 6 8-6"
              />
            </svg>
          <% end %>
          <% item.with_label { translate("navigation.messages") } %>
        <% end %>
      </li>

      <li>
        <%= render(UI::NavigationItem.new(:href => workspace_providers_path(current_workspace))) do |item| %>
          <% item.with_icon do %>
            <svg
              class="w-5 h-5 transition duration-75 group-hover:text-fg-brand"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              fill="none"
              viewBox="0 0 24 24"
            >
              <path
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19.5 12c0-.339-.035-.67-.1-.99L21 9.5l-1.5-2.598-1.8.692a6.99 6.99 0 0 0-1.714-.99L15.5 4.5h-3l-.486 2.104a6.99 6.99 0 0 0-1.714.99L8.5 6.902 7 9.5l1.6 1.51c-.065.32-.1.651-.1.99s.035.67.1.99L7 14.5l1.5 2.598 1.8-.692c.536.395 1.12.72 1.714.99L12.5 19.5h3l.486-2.104a6.99 6.99 0 0 0 1.714-.99l1.8.692L21 14.5l-1.6-1.51c.065-.32.1-.651.1-.99ZM12 15a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z"
              />
            </svg>
          <% end %>
          <% item.with_label { translate("navigation.providers") } %>
        <% end %>
      </li>

      <li>
        <%= render(UI::NavigationItem.new(:href => workspace_api_keys_path(current_workspace))) do |item| %>
          <% item.with_icon do %>
            <svg
              class="w-5 h-5 transition duration-75 group-hover:text-fg-brand"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              fill="none"
              viewBox="0 0 24 24"
            >
              <path
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 9h.01M9 15h.01M14 5H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V9l-5-4ZM14 5v4h5M9 11a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm3 3h3"
              />
            </svg>
          <% end %>
          <% item.with_label { translate("navigation.api_keys") } %>
        <% end %>
      </li>

      <li>
        <%= render(UI::NavigationItem.new(:href => workspace_deliveries_path(current_workspace))) do |item| %>
          <% item.with_icon do %>
            <svg
              class="w-5 h-5 transition duration-75 group-hover:text-fg-brand"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              fill="none"
              viewBox="0 0 24 24"
            >
              <path
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2m-6 9 2 2 4-4"
              />
            </svg>
          <% end %>
          <% item.with_label { translate("navigation.deliveries") } %>
        <% end %>
      </li>
    </ul>
  </div>
</nav>
