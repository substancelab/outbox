<nav
  id="default-sidebar"
  class="
    w-48 h-full transition-transform
    @container @max-[42rem]:w-16
  "
  aria-label="Sidebar"
>
  <div
    class="
      h-full overflow-y-auto bg-neutral-primary-soft
      border-e border-default min-w-16 flex flex-col
    "
  >
    <div class="px-3 py-3 border-b border-default">
      <% if @workspaces.size > 1 %>
        <details class="group">
          <summary class="flex items-center justify-between cursor-pointer list-none px-2 py-1.5 rounded-base hover:bg-neutral-tertiary">
            <div class="flex items-center gap-2 min-w-0">
              <svg class="w-4 h-4 shrink-0 text-body-secondary" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6c0-.6.4-1 1-1h16a1 1 0 0 1 1 1v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6Zm0 5h18M7 16h.01M11 16h2"/>
              </svg>
              <span class="text-sm font-medium text-heading truncate @max-[10rem]:hidden"><%= current_workspace.name %></span>
            </div>
            <svg class="w-3 h-3 text-body-secondary shrink-0 @max-[10rem]:hidden" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19 9-7 7-7-7"/>
            </svg>
          </summary>
          <ul class="mt-1 space-y-0.5 pb-1">
            <% @workspaces.each do |workspace| %>
              <li>
                <%= link_to workspace_messages_path(workspace),
                  class: "flex items-center px-2 py-1.5 text-sm rounded-base hover:bg-neutral-tertiary @max-[10rem]:hidden #{workspace == current_workspace ? "text-fg-brand font-medium" : "text-body"}" do %>
                  <%= workspace.name %>
                <% end %>
              </li>
            <% end %>
          </ul>
        </details>
      <% else %>
        <div class="flex items-center gap-2 px-2 py-1.5">
          <svg class="w-4 h-4 shrink-0 text-body-secondary" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6c0-.6.4-1 1-1h16a1 1 0 0 1 1 1v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6Zm0 5h18M7 16h.01M11 16h2"/>
          </svg>
          <span class="text-sm font-medium text-heading truncate @max-[10rem]:hidden"><%= current_workspace.name %></span>
        </div>
      <% end %>
    </div>

    <ul class="space-y-2 font-medium px-3 py-4 flex-1">
      <li>
        <%= render(UI::NavigationItem.new(:href => root_path)) do |item| %>
          <% item.with_icon do %>
            <svg
              class="w-5 h-5 transition duration-75 group-hover:text-fg-brand"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              fill="none"
              viewBox="0 0 24 24"
            >
              <path
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 6.025A7.5 7.5 0 1 0 17.975 14H10V6.025Z"
              />

              <path
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13.5 3c-.169 0-.334.014-.5.025V11h7.975c.011-.166.025-.331.025-.5A7.5 7.5 0 0 0 13.5 3Z"
              />
            </svg>
          <% end %>
          <% item.with_label { translate("navigation.dashboard") } %>
        <% end %>
      </li>

      <li>
        <%= render(UI::NavigationItem.new(:href => workspace_messages_path(current_workspace))) do |item| %>
          <% item.with_icon do %>
            <svg
              class="w-5 h-5 transition duration-75 group-hover:text-fg-brand"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              fill="none"
              viewBox="0 0 24 24"
            >
              <path
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 18V8a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1Zm0-10 8 6 8-6"
              />
            </svg>
          <% end %>
          <% item.with_label { translate("navigation.messages") } %>
        <% end %>
      </li>

      <li>
        <%= render(UI::NavigationItem.new(:href => "#kanban")) do |item| %>
          <% item.with_badge do %>
            <span
              class="
                bg-neutral-secondary-medium border
                border-default-medium text-heading text-xs font-medium
                px-1.5 py-0.5 rounded-sm
                @max-[10rem]:hidden
              "
            >
              Pro
            </span>
          <% end %>
          <% item.with_icon do %>
            <svg
              class="w-5 h-5 transition duration-75 group-hover:text-fg-brand"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              fill="none"
              viewBox="0 0 24 24"
            >
              <path
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 5v14M9 5v14M4 5h16a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Z"
              />
            </svg>
          <% end %>
          <% item.with_label { "Kanban" } %>
        <% end %>
      </li>

      <li>
        <%= render(UI::NavigationItem.new(:href => "#inbox")) do |item| %>
          <% item.with_badge do %>
            <span
              class="
                inline-flex items-center justify-center w-4.5 h-4.5
                ms-2 text-xs font-medium text-fg-danger-strong
                bg-danger-soft border border-danger-subtle
                rounded-full
              "
            >
              2
            </span>
          <% end %>
          <% item.with_icon do %>
            <svg
              class="w-5 h-5 transition duration-75 shrink-0 group-hover:text-fg-brand"
              aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              fill="none"
              viewBox="0 0 24 24"
            >
              <path
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 13h3.439a.991.991 0 0 1 .908.6 3.978 3.978 0 0 0 7.306 0 .99.99 0 0 1 .908-.6H20M4 13v6a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-6M4 13l2-9h12l2 9M9 7h6m-7 3h8"
              />
            </svg>
          <% end %>
          <% item.with_label { "Inbox" } %>
        <% end %>
      </li>

      <li>
        <a
          href="#"
          class="
            flex items-center px-2 py-1.5 text-body rounded-base
            hover:bg-neutral-tertiary hover:text-fg-brand group
          "
        >
          <svg
            class="w-5 h-5 transition duration-75 shrink-0 group-hover:text-fg-brand"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            fill="none"
            viewBox="0 0 24 24"
          >
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-width="2"
              d="M16 19h4a1 1 0 0 0 1-1v-1a3 3 0 0 0-3-3h-2m-2.236-4a3 3 0 1 0 0-4M3 18v-1a3 3 0 0 1 3-3h4a3 3 0 0 1 3 3v1a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1Zm8-10a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"
            />
          </svg>

          <span class="flex-1 ms-3 whitespace-nowrap @max-[10rem]:hidden">Users</span>
        </a>
      </li>

      <li>
        <a
          href="#"
          class="
            flex items-center px-2 py-1.5 text-body rounded-base
            hover:bg-neutral-tertiary hover:text-fg-brand group
          "
        >
          <svg
            class="w-5 h-5 transition duration-75 shrink-0 group-hover:text-fg-brand"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            fill="none"
            viewBox="0 0 24 24"
          >
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 10V6a3 3 0 0 1 3-3v0a3 3 0 0 1 3 3v4m3-2 .917 11.923A1 1 0 0 1 17.92 21H6.08a1 1 0 0 1-.997-1.077L6 8h12Z"
            />
          </svg>

          <span class="flex-1 ms-3 whitespace-nowrap @max-[10rem]:hidden">Products</span>
        </a>
      </li>

      <li>
        <a
          href="#"
          class="
            flex items-center px-2 py-1.5 text-body rounded-base
            hover:bg-neutral-tertiary hover:text-fg-brand group
          "
        >
          <svg
            class="w-5 h-5 transition duration-75 shrink-0 group-hover:text-fg-brand"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            fill="none"
            viewBox="0 0 24 24"
          >
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M16 12H4m12 0-4 4m4-4-4-4m3-4h2a3 3 0 0 1 3 3v10a3 3 0 0 1-3 3h-2"
            />
          </svg>

          <span class="flex-1 ms-3 whitespace-nowrap @max-[10rem]:hidden">Sign In</span>
        </a>
      </li>
    </ul>
  </div>
</nav>
