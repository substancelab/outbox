<% content_for :title, translate(".title", :sender => @provider.sender) %>

<div class="p-4 max-w-2xl">
  <div class="mb-6 flex items-center gap-2">
    <%= link_to workspace_providers_path(current_workspace), class: "text-body-secondary hover:text-heading" do %>
      <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12l4-4m-4 4 4 4"/>
      </svg>
    <% end %>
    <h1 class="text-2xl font-semibold text-heading"><%= translate(".title", :sender => @provider.sender) %></h1>
  </div>

  <% if notice %>
    <div class="flex items-center p-4 mb-4 text-sm rounded-lg border bg-success-soft border-success-subtle text-fg-success" role="alert">
      <svg class="shrink-0 inline w-4 h-4 me-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
        <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"/>
      </svg>
      <%= notice %>
    </div>
  <% end %>

  <%= render "form", :provider => @provider %>
</div>
